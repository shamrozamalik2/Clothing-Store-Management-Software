# ─────────────────────────────────────────────────────────────────
# SAS Garments – Cloud Backend Environment Variables
# Copy to .env and fill in real values before deployment.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=3001

# ── PostgreSQL ───────────────────────────────────────────────────
# Local:      postgres://user:pass@localhost:5432/sas_garments
# DigitalOcean: postgres://user:pass@db-host:25060/sas_garments?sslmode=require
DATABASE_URL=postgres://sas_user:CHANGE_ME@localhost:5432/sas_garments
DB_POOL_MAX=20
DB_SSL=false

# ── JWT (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_HEX
JWT_EXPIRES_IN=15m

# ── Refresh token (separate secret for rotation security)
REFRESH_SECRET=CHANGE_ME_ANOTHER_64_CHAR_RANDOM_HEX
REFRESH_EXPIRES_DAYS=7

# ── Security
BCRYPT_ROUNDS=12
RATE_LIMIT_MAX=300

# ── File uploads (absolute path on server, or relative to backend/)
UPLOADS_DIR=/var/www/sas-garments/uploads

# ── CORS: comma-separated origins allowed to call the API
# Electron packaged app sends null origin – add it if needed
CORS_ORIGINS=https://your-domain.com,http://localhost:5173

# ─────────────────────────────────────────────────────────────────
# SEED DEFAULTS (used by migration 002_seed.js on first run)
# Change these for each client before first deploy.
# ─────────────────────────────────────────────────────────────────
COMPANY_NAME=SAS Garments
COMPANY_SLUG=sas-garments
COMPANY_EMAIL=
COMPANY_PHONE=

ADMIN_NAME=Admin
ADMIN_EMAIL=admin@sasgarments.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
