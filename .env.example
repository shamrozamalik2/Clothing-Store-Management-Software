# ─────────────────────────────────────────────────────────────────
# SAS Garments — Backend Environment Variables
# Copy to .env and fill in real values.  NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=3001

# ── PostgreSQL ────────────────────────────────────────────────────
# Local dev : postgres://sas_user:sas_dev_pass@localhost:5432/sas_garments
# Managed   : postgres://user:pass@db.host:5432/sas_garments?sslmode=require
DATABASE_URL=postgres://sas_user:CHANGE_ME@localhost:5432/sas_garments
DB_POOL_MAX=20
DB_SSL=false

# ── JWT (generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_HEX
JWT_EXPIRES_IN=15m

REFRESH_SECRET=CHANGE_ME_ANOTHER_64_CHAR_RANDOM_HEX
REFRESH_EXPIRES_DAYS=7

# ── Super Admin JWT (can share JWT_SECRET or use a separate one) ──
SUPER_ADMIN_JWT_SECRET=CHANGE_ME_SUPER_ADMIN_SECRET

# ── Security ─────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_MAX=300
COOKIE_SECRET=CHANGE_ME_COOKIE_SECRET

# ── File uploads (absolute path on server) ───────────────────────
UPLOADS_DIR=/var/www/sas-garments/uploads

# ── CORS ─────────────────────────────────────────────────────────
# Electron sends null origin — include it if needed
CORS_ORIGINS=https://your-domain.com,http://localhost:5173

# ── Domain (for certbot / Nginx) ─────────────────────────────────
DOMAIN=your-domain.com
CERT_EMAIL=admin@your-domain.com

# ─────────────────────────────────────────────────────────────────
# PER-CLIENT SEED (migration 002 — run once on first deploy)
# ─────────────────────────────────────────────────────────────────
COMPANY_NAME=SAS Garments
COMPANY_SLUG=sas-garments
COMPANY_EMAIL=
COMPANY_PHONE=

ADMIN_NAME=Admin
ADMIN_EMAIL=admin@sasgarments.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─────────────────────────────────────────────────────────────────
# DOCKER COMPOSE (local dev)
# ─────────────────────────────────────────────────────────────────
POSTGRES_DB=sas_garments
POSTGRES_USER=sas_user
POSTGRES_PASSWORD=sas_dev_pass
POSTGRES_PORT=5432

PGADMIN_EMAIL=dev@sas.local
PGADMIN_PASSWORD=devpass

# ─────────────────────────────────────────────────────────────────
# BACKUP
# ─────────────────────────────────────────────────────────────────
BACKUP_DIR=/var/backups/sas-garments
RETAIN_DAYS=14
