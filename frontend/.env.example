# Cloud API URL — where the backend is hosted
# In dev this is proxied via vite.config.js; in production builds set this to your server URL
VITE_API_URL=https://your-server.com

# Company slug — identifies which company this build is for
# Must match the value used when seeding the database (COMPANY_SLUG in backend .env)
VITE_COMPANY_SLUG=sas-garments
